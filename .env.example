# Quoril Supabase — used by the waitlist API route (server-side).
# These are the same project the desktop app syncs to.

# Public project URL + anon/publishable key (safe to expose).
NEXT_PUBLIC_SUPABASE_URL=https://izxoyfydqsopvaywrtuz.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_XTpgjyAzkWJJ5RwysjRZlg_4jjsZV4Q

# ── Admin panel (/admin) ────────────────────────────────────
# The service-role key bypasses RLS so the panel can read and
# delete waitlist rows the public can't see. Required for the
# admin panel. NEVER expose this with a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated allowlist of emails permitted to sign in to
# the admin panel. An empty list fails closed (nobody allowed).
ADMIN_EMAILS=

# Secret URL slug for the admin panel. Reachable only at /<ADMIN_PATH>;
# the literal /admin returns 404. This is an obscurity layer, not auth —
# the real lock is ADMIN_EMAILS + the Supabase JWT check. Generate one:
#   node -e "console.log(require('crypto').randomBytes(18).toString('base64url'))"
ADMIN_PATH=

# Optional explicit server-side URL / anon key. The panel falls
# back to the NEXT_PUBLIC_ values above when these are unset.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
